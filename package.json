{
  "name": "music-downloader",
  "version": "1.0.0",
  "description": "music-downloader",
  "main": "index.js",
  "scripts": {
    "pack:win": "npm run build && electron-builder build --config electron-builder.config.js --win",
    "pack:mac": "npm run build && electron-builder build --config electron-builder.config.js --mac",
    "package": "npm run build && electron-builder build --config electron-builder.config.js --publish always",
    "start": "node scripts/dev.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:renderer": "cd src/renderer/main && npm run build",
    "build:main": "webpack -c config/webpack.main.config.js",
    "lint": "eslint src/ --ext .ts --fix",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joey2217/music-downloader.git"
  },
  "keywords": [],
  "author": "Joey",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joey2217/music-downloader/issues"
  },
  "homepage": "https://github.com/joey2217/music-downloader#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.30.6",
    "@typescript-eslint/parser": "^5.30.6",
    "electron": "^19.0.8",
    "electron-builder": "^23.1.0",
    "eslint": "^8.0.1",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "ts-loader": "^9.3.1",
    "typescript": "^4.7.4",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0"
  }
}
